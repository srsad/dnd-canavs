PORT=3000
FRONTEND_URL=http://localhost:5173
JWT_SECRET=change-me
DATABASE_URL="postgresql://user:password@localhost:5432/dnd_canvas"

# Optional: Redis for WebSocket session store (survives backend restarts). Omit to use in-memory.
REDIS_URL=redis://localhost:6379

# S3-compatible storage (canvas images: UI uploads via POST /rooms/:slug/uploads/image; presign optional). Omit to disable uploads.
S3_ENDPOINT=https://s3.example.com
S3_BUCKET=your-bucket
S3_ACCESS_KEY_ID=your-access-key
S3_SECRET_ACCESS_KEY=your-secret-key
# Often us-east-1 for non-AWS providers
S3_REGION=us-east-1
# 1 or true for many MinIO / S3-compatible APIs
S3_FORCE_PATH_STYLE=true
# Full public base URL for objects (no trailing slash). If unset: {S3_ENDPOINT}/{S3_BUCKET}
# S3_PUBLIC_BASE_URL=https://cdn.example.com/my-bucket
# Optional: presigned URL lifetime in seconds (default 900, max 3600)
# S3_PRESIGN_EXPIRES_SEC=900
# Optional: e.g. public-read if your provider supports ACL on PutObject
# S3_OBJECT_ACL=public-read

# Optional Swift API (not used by the app today; S3 API above is used for uploads)
# S3_SWIFT_URL=https://swift.example.com
# S3_SWIFT_ACCESS_KEY=
# S3_SWIFT_SECRET_ACCESS_KEY=
