datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  displayName  String
  passwordHash String
  createdAt    DateTime @default(now())
}

model Room {
  id             String   @id @default(uuid())
  slug           String   @unique
  title          String
  createdAt      DateTime @default(now())
  createdBy      Json     // RoomParticipant
  canvas         Json     // RoomCanvasState
  diceLogs       Json     @default("[]") // DiceRollLog[]
  canvasHistory  Json     @default("[]") // RoomCanvasState[]
  chatMessages   Json     @default("[]") // ChatMessage[]
  hostSecretHash String? // sha256 hex; guest GM reconnect only, never exposed in API payloads
  participantAcl Json     @default("{}") // Record<participantId, { permissions?: Partial<...> }>

  auditEvents RoomAuditEvent[]
}

model RoomAuditEvent {
  id        String   @id @default(uuid())
  roomId    String
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  actorId   String?
  type      String
  payload   Json

  @@index([roomId, createdAt])
}
